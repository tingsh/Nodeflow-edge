{
  "gateway": {
    "serial_number": "REPLACE_WITH_SERIAL_NUMBER"
  },
  "mqtt": {
    "host": "REPLACE_WITH_MQTT_BROKER_HOST",
    "port": 8883,
    "topic": "v1/gateway/telemetry",
    "username": "REPLACE_WITH_SERIAL_NUMBER",
    "password": "REPLACE_WITH_CLAIM_CODE",
    "qos": 1,
    "client_id": "novena-gateway-REPLACE_WITH_SERIAL_NUMBER",
    "max_queue_size": 100000,
    "reconnect_delay_min": 1,
    "reconnect_delay_max": 60,
    "tls": {
      "mode": "one-way",
      "ca_certs": "/opt/novena-gateway/certs/ca.crt"
    }
  },
  "logging": {
    "file": "/opt/novena-gateway/logs/novena-gateway.log",
    "max_bytes": 5242880,
    "backup_count": 5
  },
  "features": {
    "remote_logging": {
      "enabled": true,
      "min_level": "INFO",
      "batch_size": 20,
      "flush_interval_seconds": 5,
      "max_buffer_size": 500
    },
    "attribute_sync": {
      "enabled": true,
      "heartbeat_interval_seconds": 60
    },
    "remote_config": {
      "enabled": true,
      "backup_dir": "config_backups"
    },
    "rpc": {
      "enabled": true
    },
    "discovery": {
      "enabled": true,
      "scan_on_boot": true,
      "scan_interval_seconds": 3600,
      "rtu_slave_range": [1, 32],
      "rtu_baud_rates": [9600, 19200],
      "tcp_subnet_scan": true,
      "tcp_scan_timeout_ms": 500
    }
  },
  "connectors": []
}
